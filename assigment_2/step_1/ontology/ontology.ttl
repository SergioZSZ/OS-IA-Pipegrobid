<https://g4.org/ontology/research-funding#> rdf:type owl:Ontology ;
                                             <http://purl.org/dc/elements/1.1/creator> "G4_OPENSCIENCE" ;
                                             <http://purl.org/dc/elements/1.1/title> "Ontology for funding researching" ;
                                             <http://purl.org/dc/terms/license> "https://www.apache.org/licenses/LICENSE-2.0" ;
                                             owl:versionInfo "0.0.1" ;
